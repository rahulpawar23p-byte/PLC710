<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.16">
  <POU Name="FB_TurnTable_0_180" Id="{f66d59a1-2890-4604-ac64-b1ee57cd8724}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_TurnTable_0_180
VAR_INPUT
	// Inputs
    Start_0     : BOOL;
    Start_180   : BOOL;
    LS_0        : BOOL;
    LS_180      : BOOL;
    StopBtn     : BOOL;

END_VAR
VAR_OUTPUT
	// Outputs
    Motor_CW    : BOOL;
    Motor_CCW   : BOOL;
    Reached_180 : BOOL;
    Reached_0   : BOOL;
END_VAR
VAR
	// Internal states
    Move_0      : BOOL := FALSE;
    Move_180    : BOOL := FALSE;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[// =========================
// COMMAND LOGIC
// =========================
// Move to 0°
IF Start_0 AND NOT LS_0 THEN
    Move_0 := TRUE;
    Move_180 := FALSE;
END_IF;

// Move to 180°
IF Start_180 AND NOT LS_180 THEN
    Move_180 := TRUE;
    Move_0 := FALSE;
END_IF;

// =========================
// STOP LOGIC
// =========================
IF StopBtn THEN
    Move_0 := FALSE;
    Move_180 := FALSE;
END_IF;

// =========================
// LIMIT SWITCH STOP
// =========================
IF LS_0 THEN
    Move_0 := FALSE;
END_IF;
IF LS_180 THEN
    Move_180 := FALSE;
END_IF;

// =========================
// SAFETY: BOTH LIMIT ACTIVE
// =========================
IF LS_0 AND LS_180 THEN
    Move_0 := FALSE;
    Move_180 := FALSE;
END_IF;

// =========================
// OUTPUT LOGIC
// =========================
Motor_CCW := Move_0;     // Move toward 0°
Motor_CW  := Move_180;   // Move toward 180°

// =========================
// INTERLOCK (VERY IMPORTANT)
// =========================
IF Motor_CW THEN
    Motor_CCW := FALSE;
END_IF;
IF Motor_CCW THEN
    Motor_CW := FALSE;
END_IF;

// =========================
// POSITION REACHED SIGNALS
// =========================
Reached_0   := LS_0 AND NOT Move_0;
Reached_180 := LS_180 AND NOT Move_180;
 
// =========================
// COMMAND LOGIC
// =========================
// Move to 0°

IF Start_0 AND NOT LS_0 THEN
    Move_0 := TRUE;
    Move_180 := FALSE;
END_IF;
// Move to 180°
IF Start_180 AND NOT LS_180 THEN
    Move_180 := TRUE;
    Move_0 := FALSE;
END_IF;

// =========================
// STOP LOGIC
// =========================
IF StopBtn THEN
    Move_0 := FALSE;
    Move_180 := FALSE;
END_IF;

// =========================
// LIMIT SWITCH STOP
// =========================
IF LS_0 THEN
    Move_0 := FALSE;
END_IF;
IF LS_180 THEN
    Move_180 := FALSE;
END_IF;

// =========================
// SAFETY: BOTH LIMIT ACTIVE
// =========================
IF LS_0 AND LS_180 THEN
    Move_0 := FALSE;
    Move_180 := FALSE;
END_IF;

// =========================
// OUTPUT LOGIC
// =========================
Motor_CCW := Move_0;     // Move toward 0°
Motor_CW  := Move_180;   // Move toward 180°

// =========================
// INTERLOCK (VERY IMPORTANT)
// =========================
IF Motor_CW THEN
    Motor_CCW := FALSE;
END_IF;
IF Motor_CCW THEN
    Motor_CW := FALSE;
END_IF;

// =========================
// POSITION REACHED SIGNALS
// =========================
Reached_0   := LS_0 AND NOT Move_0;
Reached_180 := LS_180 AND NOT Move_180;
 ]]></ST>
    </Implementation>
